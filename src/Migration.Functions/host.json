{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request;Exception;Event"
      }
    }
  },
  "extensions": {
    "serviceBus": {
      "autoCompleteMessages": false,
      "maxConcurrentCalls": 5,
      "prefetchCount": 0,
      "maxAutoLockRenewalDuration": "12:00:00"
    }
  }
}
